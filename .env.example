# Changelog (About page reads GitHub Releases)
# CHANGELOG_GITHUB_REPO="owner/repo"
# Optional: higher API rate limits / private repos (server-only, never NEXT_PUBLIC_)
# GITHUB_TOKEN=""

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/wonder_weekly?schema=public"
# Optional: production DB URL for scripts (e.g. museum.ts --prod --save)
# DATABASE_URL_PROD="postgresql://..."

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-change-in-production"
# Required for Auth.js v5 when running locally (trust localhost)
AUTH_TRUST_HOST="true"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Cloudflare R2 (for image uploads)
R2_ACCOUNT_ID="your-r2-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="wonder-weekly"
R2_PUBLIC_URL="https://your-r2-public-url.com"

# Resend (transactional email)
RESEND_API_KEY="your-resend-api-key"
RESEND_FROM_EMAIL="Prompts <hello@yourdomain.com>"
# CAN-SPAM: physical mailing address shown in email footers (e.g. "123 Main St, City, State ZIP")
# MAILING_ADDRESS="Your Company, 123 Main St, City, State ZIP"

# Vercel AI Gateway (image editor auto-fix)
# Prefer OIDC with `vercel env pull` (VERCEL_OIDC_TOKEN) instead of static keys.
# AI_GATEWAY_API_KEY is optional fallback for local/dev or non-Vercel environments.
# AI_GATEWAY_API_KEY=""
# Optional override for image auto-fix model
# IMAGE_EDITOR_AUTOFIX_MODEL="google/gemini-3.1-flash-image-preview"

# Sentry (error monitoring, tracing, session replay)
# Create a project at https://sentry.io and copy the DSN from Project Settings > Client Keys (DSN).
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
# Optional: Sentry environment (issue grouping in the UI). Defaults: VERCEL_ENV, else NODE_ENV.
# For browser events, set NEXT_PUBLIC_VERCEL_ENV to the same value as VERCEL_ENV on Vercel (e.g. production / preview).
# SENTRY_ENVIRONMENT=""
# NEXT_PUBLIC_VERCEL_ENV=""
# Auth token for source map uploads: https://sentry.io/settings/auth-tokens/ (scopes: project:releases, org:read)
# Use .env.sentry-build-plugin (gitignored) for local builds or set in CI.
# SENTRY_AUTH_TOKEN=""
# SENTRY_ORG=""
# SENTRY_PROJECT=""

# E2E Testing (Playwright)
# Email is used as the credentials username for non-production login.
# Password is used for both credentials auth and test user bootstrap.
E2E_USER_EMAIL="create.spot.user@gmail.com"
E2E_USER_PASSWORD=""  # Set in .env, not committed
# Secret for the non-production test bootstrap API (POST /api/test/users). Required for e2e credentials login.
E2E_BOOTSTRAP_SECRET=""  # Set in .env, e.g. a random string; not committed
