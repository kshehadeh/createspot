{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    "apps/web": {
      "entry": [
        "app/**/*.{ts,tsx}",
        "components/**/*.{ts,tsx}",
        "lib/**/*.{ts,tsx}",
        "emails/**/*.{ts,tsx}",
        "scripts/**/*.{ts,tsx}"
      ],
      "ignore": [
        "postcss.config.mjs",
        "scripts/**/*.ts",
        "app/@breadcrumb/**",
        "app/(public)/loading.tsx",
        "app/(app)/loading.tsx",
        "app/creators/[creatorid]/opengraph-image.tsx",
        "app/creators/[creatorid]/portfolio/opengraph-image.tsx",
        "app/creators/[creatorid]/collections/[collectionid]/opengraph-image.tsx",
        "app/creators/[creatorid]/s/[submissionid]/opengraph-image.tsx",
        "app/inspire/exhibition/[exhibitId]/opengraph-image.tsx",
        "data/**",
        "e2e/**",
        "playwright.config.ts"
      ]
    }
  },
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  },
  "ignoreBinaries": [],
  "tags": ["-lintignore"]
}
