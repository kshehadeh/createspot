// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// NextAuth.js models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Share status enum for submissions
enum ShareStatus {
  PRIVATE // Only visible to owner
  PROFILE // Visible on profile pages
  PUBLIC  // Visible everywhere (galleries, profile pages, etc.)
}

// Application models
model User {
  id                   String       @id @default(cuid())
  email                String       @unique
  emailVerified        DateTime?
  passwordHash         String?      @db.Text // Non-production credentials login only
  name                 String?
  image                String?
  profileImageUrl      String?      // Custom profile image uploaded by user
  profileImageFocalPoint Json?      // {"x": 50, "y": 30} where x,y are 0-100 percentages
  isAdmin              Boolean      @default(false)
  bio                  String?      @db.Text
  instagram            String?
  twitter              String?
  linkedin             String?
  website              String?
  city                 String?
  stateProvince        String?
  country              String?
  language             String       @default("en") // ISO 639-1 code: "en", "es"
  latitude             Float?
  longitude            Float?
  slug                 String?      @unique // URL-friendly identifier (e.g., "karim-shehadeh")
  featuredSubmissionId String?      @unique
  // Image protection settings
  enableWatermark      Boolean      @default(false)
  watermarkPosition    String       @default("bottom-right") // "bottom-right" | "bottom-left" | "top-right" | "top-left"
  protectFromDownload  Boolean      @default(true)
  protectFromAI        Boolean      @default(true)
  emailOnFavorite      Boolean      @default(true)
  emailFeatureUpdates  Boolean      @default(true)
  emailOnBadgeAward    Boolean      @default(true)
  emailOnNewFollowerPost Boolean    @default(true)
  emailOnNewFollower    Boolean     @default(true)
  welcomeEmailSent     Boolean      @default(false)
  tutorial             Json         @default("{\"status\": \"enabled\", \"global\": {}}")
  onboardingDismissedAt DateTime?   // When user dismissed the onboarding checklist
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  accounts           Account[]
  sessions           Session[]
  submissions        Submission[]
  favorites          Favorite[]
  featuredSubmission Submission?      @relation("FeaturedSubmission", fields: [featuredSubmissionId], references: [id], onDelete: SetNull)
  profileViews       ProfileView[]    @relation("ProfileViews")
  viewedProfiles     ProfileView[]    @relation("ViewedProfiles")
  submissionViews    SubmissionView[] @relation("SubmissionViews")
  curatedExhibits    Exhibit[]        @relation("CuratedExhibits")
  featuredArtistInExhibits Exhibit[]  @relation("FeaturedArtistInExhibits")
  critiques          Critique[]       @relation("Critiques")
  comments           Comment[]        @relation("Comments")
  notificationLogs   NotificationLog[] @relation("NotificationLogs")
  badgeAwards        BadgeAward[]
  collections        Collection[]
  following          Follow[]       @relation("Following")
  followers          Follow[]       @relation("Followers")
  blocking           Block[]        @relation("Blocking")
  blockedBy          Block[]        @relation("BlockedBy")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String   // The user who is following
  followingId String   // The user being followed
  createdAt   DateTime @default(now())

  follower  User @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Block {
  id         String   @id @default(cuid())
  blockerId  String   // The user who is blocking
  blockedId  String   // The user being blocked
  createdAt  DateTime @default(now())

  blocker User @relation("Blocking", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlockedBy", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model Submission {
  id             String      @id @default(cuid())
  userId         String
  title          String?
  imageUrl                 String?
  imageFocalPoint           Json?      // {"x": 50, "y": 30} where x,y are 0-100 percentages
  imageProcessingMetadata   Json?      // { watermarked?, compressed?, format? } for UI display
  imageProcessedAt         DateTime?   // When post-processing completed
  text           String?     @db.Text // Sanitized HTML
  isPortfolio    Boolean     @default(false) // Show in portfolio section
  portfolioOrder Int?        // Custom ordering for portfolio items (lower = first)
  tags           String[]    @default([])    // Array of tags for portfolio items
  category       String?     // e.g., "Photography", "Writing", "Digital Art"
  shareStatus    ShareStatus @default(PUBLIC) // Visibility: PRIVATE, PROFILE, or PUBLIC
  referenceImageUrl String?  // Optional reference/inspiration image URL
  critiquesEnabled Boolean   @default(false) // Allow critiques on this submission
  commentsEnabled  Boolean   @default(true) // Allow comments on this submission
  isWorkInProgress Boolean   @default(false) // Creator intent: "not done yet"
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  favorites  Favorite[]
  views      SubmissionView[]
  featuredBy User?            @relation("FeaturedSubmission")
  exhibitSubmissions ExhibitSubmission[]
  featuredInExhibits Exhibit[] @relation("FeaturedInExhibits")
  critiques  Critique[]
  comments   Comment[]
  collectionSubmissions CollectionSubmission[]
  shortLinks ShortLink[]
  progressions Progression[]

  @@index([userId, isPortfolio])
  @@index([userId, isPortfolio, portfolioOrder])
  @@index([shareStatus])
  @@index([shareStatus, isPortfolio, createdAt])
}

model Progression {
  id           String   @id @default(cuid())
  submissionId String
  imageUrl     String?              // Optional - progression can be image, text, or both
  text         String?  @db.Text    // The creative work itself (sanitized HTML, like submission text)
  comment      String?  @db.Text    // Creator's note about this progression step
  order        Int                  // Display order (0-indexed, lower = earlier in progression)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([submissionId, order])
}

model Favorite {
  id           String   @id @default(cuid())
  userId       String
  submissionId String
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([userId, submissionId])
  @@index([userId])
  @@index([submissionId])
}

model ProfileView {
  id            String   @id @default(cuid())
  profileUserId String
  viewerUserId  String?
  viewerIpHash  String   // Hashed IP for anonymous tracking
  viewedAt      DateTime @default(now())

  profileUser User  @relation("ProfileViews", fields: [profileUserId], references: [id], onDelete: Cascade)
  viewer      User? @relation("ViewedProfiles", fields: [viewerUserId], references: [id], onDelete: SetNull)

  @@unique([profileUserId, viewerUserId])
  @@unique([profileUserId, viewerIpHash])
  @@index([profileUserId])
}

model SubmissionView {
  id           String   @id @default(cuid())
  submissionId String
  viewerUserId String?
  viewerIpHash String   // Hashed IP for anonymous tracking
  viewedAt     DateTime @default(now())

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  viewer     User?      @relation("SubmissionViews", fields: [viewerUserId], references: [id], onDelete: SetNull)

  @@unique([submissionId, viewerUserId])
  @@unique([submissionId, viewerIpHash])
  @@index([submissionId])
}

model Exhibit {
  id                String   @id @default(cuid())
  title             String
  description       String?  @db.Text
  startTime         DateTime
  endTime           DateTime?
  isActive          Boolean  @default(true)
  curatorId         String
  featuredArtistId  String?
  featuredSubmissionId String? @unique
  allowedViewTypes  String[] @default(["gallery", "constellation", "global"])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  curator           User     @relation("CuratedExhibits", fields: [curatorId], references: [id], onDelete: Cascade)
  featuredArtist    User?    @relation("FeaturedArtistInExhibits", fields: [featuredArtistId], references: [id], onDelete: SetNull)
  featuredSubmission Submission? @relation("FeaturedInExhibits", fields: [featuredSubmissionId], references: [id], onDelete: SetNull)
  submissions       ExhibitSubmission[]
  shortLinks        ShortLink[]

  @@index([startTime, endTime])
  @@index([isActive])
}

model ExhibitSubmission {
  id           String   @id @default(cuid())
  exhibitId    String
  submissionId String
  order        Int      // Custom ordering (lower = first)
  createdAt    DateTime @default(now())

  exhibit      Exhibit     @relation(fields: [exhibitId], references: [id], onDelete: Cascade)
  submission   Submission  @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([exhibitId, submissionId])
  @@index([exhibitId, order])
}

model Critique {
  id           String    @id @default(cuid())
  submissionId String
  critiquerId  String    // User who wrote the critique
  critique     String    @db.Text // HTML text (from RichTextEditor)
  response     String?   @db.Text // Creator's reply (HTML, nullable, from RichTextEditor)
  seenAt       DateTime? // When creator viewed the critique (NULL = unseen)
  selectionData Json?    // Optional selection metadata (image region or text selection)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  critiquer  User      @relation("Critiques", fields: [critiquerId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([critiquerId])
  @@index([submissionId, critiquerId])
}

model NotificationLog {
  id     String   @id @default(cuid())
  type   String   // e.g., "NEW_PROMPT", "PROMPT_ENDING", "WEEKLY_DIGEST"
  meta   Json     // { "promptId": "xxx" } or other event-specific data
  userId String?  // NULL for broadcast notifications, set for user-specific
  sentAt DateTime @default(now())

  user User? @relation("NotificationLogs", fields: [userId], references: [id], onDelete: Cascade)

  @@index([type, sentAt])
  @@index([userId])
}

model BadgeAward {
  id         String   @id @default(cuid())
  userId     String
  badgeKey   String
  awardedAt  DateTime @default(now())
  notifiedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeKey])
  @@index([userId])
  @@index([awardedAt])
}

model Collection {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?  @db.Text
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  submissions CollectionSubmission[]
  shortLinks  ShortLink[]

  @@index([userId])
  @@index([userId, isPublic])
}

model ShortLink {
  id           String   @id @default(cuid())
  code         String   @unique
  submissionId  String?  @unique
  collectionId  String?  @unique
  exhibitId    String?  @unique
  createdAt    DateTime @default(now())

  submission  Submission?  @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  collection Collection?  @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  exhibit    Exhibit?     @relation(fields: [exhibitId], references: [id], onDelete: Cascade)

  @@index([code])
}

model CollectionSubmission {
  id           String   @id @default(cuid())
  collectionId String
  submissionId String
  order        Int
  createdAt    DateTime @default(now())

  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([collectionId, submissionId])
  @@index([collectionId, order])
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model Comment {
  id           String     @id @default(cuid())
  submissionId String
  userId       String
  parentId     String?    // NULL = top-level, set = reply
  body         String     @db.Text
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?  // Soft delete (preserves thread structure)

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  user       User       @relation("Comments", fields: [userId], references: [id], onDelete: Cascade)
  parent     Comment?   @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    Comment[]  @relation("CommentReplies")

  @@index([submissionId, createdAt])
  @@index([parentId])
  @@index([userId])
}
